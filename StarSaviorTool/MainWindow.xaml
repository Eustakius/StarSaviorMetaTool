<Window x:Class="StarSaviorTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:StarSaviorTool.ViewModels"
        Title="Star Savior Meta Tool"
        Height="850" Width="1320" MinWidth="960" MinHeight="650"
        Background="{StaticResource BgDarkBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <!-- Tier Color Converter is manual via Triggers instead -->
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ═══ HEADER BAR ═══ -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="0" Padding="24,16" BorderThickness="0,0,0,1"
                BorderBrush="{StaticResource BorderBrush}">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="#161B22" Offset="0"/>
                    <GradientStop Color="#1C2128" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="★" FontSize="26" Foreground="#FFD700" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="STAR SAVIOR" FontSize="18" FontWeight="Bold" Foreground="#E6EDF3"/>
                        <TextBlock Text="META TOOL" FontSize="10" Foreground="#58A6FF" FontWeight="SemiBold"
                                   Margin="1,-1,0,0"/>
                    </StackPanel>
                    <Border CornerRadius="4" Padding="6,3" Margin="16,0,0,0" VerticalAlignment="Center"
                            Background="#0D1117" BorderBrush="#30363D" BorderThickness="1">
                        <TextBlock Text="{Binding MetaVersion, StringFormat='v{0}'}" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                </StackPanel>

                <!-- Right Controls -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border CornerRadius="10" Padding="10,5" Margin="0,0,16,0"
                            Background="#0D1117" VerticalAlignment="Center">
                        <TextBlock Text="{Binding ConnectionStatus}" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                    </Border>
                    <Button Content="⟳  Enrich Data" Command="{Binding EnrichDataCommand}" Margin="0,0,10,0"/>
                    <Button Content="↻  Reload" Command="{Binding LoadDataCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ═══ MAIN TABS ═══ -->
        <!-- ═══════════════════════════════════════════════════ -->
        <TabControl Grid.Row="1" Background="{StaticResource BgDarkBrush}" BorderThickness="0" Padding="0"
                    Margin="0,-1,0,0">

            <!-- ══════════════════════════════════════════════ -->
            <!-- ═══ TAB 1: TIER LIST ═══ -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="  Tier List">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="400"/>
                        <ColumnDefinition Width="360"/>
                    </Grid.ColumnDefinitions>

                    <!-- ─── Left: Character Grid ─── -->
                    <DockPanel Grid.Column="0" Margin="0,0,16,0">

                        <!-- Filter Bar -->
                        <Border DockPanel.Dock="Top" Background="#161B22" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,14"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="Tier" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                <ComboBox Width="85" ItemsSource="{Binding TierFilters}"
                                          SelectedItem="{Binding SelectedTierFilter}" Margin="0,0,20,0"/>
                                <TextBlock Text="Role" Foreground="{StaticResource TextSecondaryBrush}"
                                           VerticalAlignment="Center" Margin="0,0,8,0" FontSize="12"/>
                                <ComboBox Width="110" ItemsSource="{Binding RoleFilters}"
                                          SelectedItem="{Binding SelectedRoleFilter}" Margin="0,0,20,0"/>
                                <TextBox Width="220" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                            </StackPanel>
                        </Border>

                        <!-- Character List -->
                        <ListBox ItemsSource="{Binding FilteredCharacters}"
                                 SelectedItem="{Binding SelectedCharacter}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 Background="#0D1117" BorderThickness="1" BorderBrush="#30363D">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="#161B22" CornerRadius="8" Padding="14,11" Margin="2,2"
                                                        BorderBrush="#21262D" BorderThickness="1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1C2128"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#172A45"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Tier Badge -->
                                        <Border x:Name="tierBadge" Grid.Column="0" CornerRadius="6"
                                                Width="36" Height="26" VerticalAlignment="Center">
                                            <Border.Background>
                                                <SolidColorBrush Color="#2D333B"/>
                                            </Border.Background>
                                            <TextBlock x:Name="tierText" Text="{Binding Tier}" FontWeight="Bold"
                                                       FontSize="12" Foreground="#FFD700"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Name -->
                                        <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14"
                                                   FontWeight="SemiBold" Foreground="#E6EDF3"
                                                   VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                                        <!-- Role -->
                                        <Border Grid.Column="2" CornerRadius="4" Padding="8,3" Margin="8,0"
                                                Background="#0D1117" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Role}" FontSize="11"
                                                       Foreground="#BC8CFF" FontWeight="Medium"/>
                                        </Border>

                                        <!-- Element -->
                                        <Border Grid.Column="3" CornerRadius="4" Padding="8,3"
                                                Background="#0D1117" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Element}" FontSize="11"
                                                       Foreground="#58A6FF" FontWeight="Medium"/>
                                        </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Tier}" Value="T0">
                                            <Setter TargetName="tierBadge" Property="Background" Value="#3D2E00"/>
                                            <Setter TargetName="tierText" Property="Foreground" Value="#FFD700"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="SS">
                                            <Setter TargetName="tierBadge" Property="Background" Value="#3D1518"/>
                                            <Setter TargetName="tierText" Property="Foreground" Value="#FF6B6B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="S">
                                            <Setter TargetName="tierBadge" Property="Background" Value="#12284A"/>
                                            <Setter TargetName="tierText" Property="Foreground" Value="#58A6FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="A">
                                            <Setter TargetName="tierBadge" Property="Background" Value="#1A3320"/>
                                            <Setter TargetName="tierText" Property="Foreground" Value="#3FB950"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="B">
                                            <Setter TargetName="tierBadge" Property="Background" Value="#21262D"/>
                                            <Setter TargetName="tierText" Property="Foreground" Value="#8B949E"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- ─── Right: Character Detail Panel ─── -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="20,18"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#161B22" Offset="0"/>
                                <GradientStop Color="#13171E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel DataContext="{Binding SelectedCharacter}">

                                <!-- Character Name -->
                                <TextBlock Text="{Binding Name, FallbackValue='Select a character'}"
                                           FontSize="22" FontWeight="Bold" Foreground="#E6EDF3"
                                           TextWrapping="Wrap" Margin="0,0,0,12"/>

                                <!-- Badges Row -->
                                <WrapPanel Margin="0,0,0,18">
                                    <Border CornerRadius="6" Padding="10,5" Margin="0,0,8,4" Background="#3D2E00">
                                        <TextBlock Text="{Binding Tier}" FontWeight="Bold" Foreground="#FFD700" FontSize="13"/>
                                    </Border>
                                    <Border CornerRadius="6" Padding="10,5" Margin="0,0,8,4" Background="#2A1B3D">
                                        <TextBlock Text="{Binding Role}" Foreground="#BC8CFF" FontSize="13" FontWeight="Medium"/>
                                    </Border>
                                    <Border CornerRadius="6" Padding="10,5" Margin="0,0,8,4" Background="#12284A">
                                        <TextBlock Text="{Binding Element}" Foreground="#58A6FF" FontSize="13" FontWeight="Medium"/>
                                    </Border>
                                </WrapPanel>

                                <!-- Separator -->
                                <Border Height="1" Background="#21262D" Margin="0,0,0,16"/>

                                <!-- Tags Section -->
                                <TextBlock Text="TAGS" FontSize="11" FontWeight="Bold"
                                           Foreground="#484F58" Margin="0,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding Tags}" Margin="0,0,0,18">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="4" Padding="8,3" Margin="0,0,6,5"
                                                    Background="#0D1117" BorderBrush="#1C2871" BorderThickness="1">
                                                <TextBlock Text="{Binding}" FontSize="11" Foreground="#79C0FF"
                                                           FontFamily="Consolas, Courier New"/>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <!-- Why Meta Section -->
                                <Border Background="#0D2818" CornerRadius="8" Padding="14,12" Margin="0,0,0,14"
                                        BorderBrush="#1A3320" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="WHY META" FontSize="11" FontWeight="Bold"
                                                   Foreground="#3FB950" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding WhyMeta}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="12.5" Foreground="#C9D1D9"
                                                               TextWrapping="Wrap" Margin="0,2,0,3"
                                                               LineHeight="18">
                                                        <Run Text="›  " Foreground="#3FB950"/>
                                                        <Run Text="{Binding Mode=OneWay}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Weakness Section -->
                                <Border Background="#2A1A00" CornerRadius="8" Padding="14,12" Margin="0,0,0,14"
                                        BorderBrush="#3D2700" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="WEAKNESS" FontSize="11" FontWeight="Bold"
                                                   Foreground="#D29922" Margin="0,0,0,8"/>
                                        <ItemsControl ItemsSource="{Binding Weakness}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="12.5" Foreground="#C9D1D9"
                                                               TextWrapping="Wrap" Margin="0,2,0,3"
                                                               LineHeight="18">
                                                        <Run Text="›  " Foreground="#D29922"/>
                                                        <Run Text="{Binding Mode=OneWay}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                                <!-- Source Section -->
                                <Border Background="#0D1117" CornerRadius="8" Padding="14,10"
                                        BorderBrush="#21262D" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock Text="SOURCE" FontSize="11" FontWeight="Bold"
                                                   Foreground="#484F58" Margin="0,0,0,6"/>
                                        <ItemsControl ItemsSource="{Binding Source}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock FontSize="11.5" Foreground="#8B949E" Margin="0,1">
                                                        <Run Text="📌 "/>
                                                        <Run Text="{Binding Mode=OneWay}"/>
                                                    </TextBlock>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

            <!-- ══════════════════════════════════════════════ -->
            <!-- ═══ TAB 2: TEAM BUILDER ═══ -->
            <!-- ══════════════════════════════════════════════ -->
            <TabItem Header="  Team Builder">
                <Grid Margin="20,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="350"/>
                        <ColumnDefinition Width="400"/>
                    </Grid.ColumnDefinitions>

                    <!-- ─── Left: Character Picker ─── -->
                    <DockPanel Grid.Column="0" Margin="0,0,16,0">

                        <!-- Action Bar -->
                        <Border DockPanel.Dock="Top" Background="#161B22" CornerRadius="8"
                                Padding="14,10" Margin="0,0,0,12"
                                BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                            <StackPanel>
                                <Grid Margin="0,0,0,10">
                                    <TextBlock Text="Build your team (max 4 characters)"
                                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"
                                               VerticalAlignment="Center"/>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                                        <TextBlock Text="Team Focus:" Foreground="#8B949E" FontSize="11" VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <ComboBox Width="110" ItemsSource="{Binding TeamFocusOptions}" SelectedItem="{Binding SelectedTeamFocus}"/>
                                    </StackPanel>
                                </Grid>
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="＋ Add" Command="{Binding AddToTeamCommand}" Margin="0,0,8,0"/>
                                    <Button Content="－ Remove" Command="{Binding RemoveFromTeamCommand}" Margin="0,0,8,0"/>
                                    <Button Content="⚡ Auto-Fix" Command="{Binding AutoFixTeamCommand}" Margin="0,0,8,0"
                                            Foreground="#58A6FF"/>
                                    <Button Content="✕ Clear" Command="{Binding ClearTeamCommand}"
                                            Foreground="#F85149"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Selected Team Display -->
                        <Border DockPanel.Dock="Top" Margin="0,0,0,12" MinHeight="60">
                            <StackPanel>
                                <TextBlock Text="CURRENT TEAM" FontSize="11" FontWeight="Bold"
                                           Foreground="#484F58" Margin="4,0,0,8"/>
                                <ItemsControl ItemsSource="{Binding SelectedTeam}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border CornerRadius="8" Padding="14,10" Margin="0,0,10,8"
                                                    BorderBrush="#58A6FF" BorderThickness="1">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#12284A" Offset="0"/>
                                                        <GradientStop Color="#161B22" Offset="1"/>
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="#E6EDF3"/>
                                                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                                                        <TextBlock Text="{Binding Tier}" FontSize="11" Foreground="#FFD700"
                                                                   FontWeight="Bold" Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding Role}" FontSize="11" Foreground="#BC8CFF"
                                                                   Margin="0,0,10,0"/>
                                                        <TextBlock Text="{Binding Element}" FontSize="11" Foreground="#58A6FF"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Character Picker List -->
                        <ListBox ItemsSource="{Binding FilteredCharacters}"
                                 SelectedItem="{Binding SelectedCharacter}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                                    <Setter Property="Cursor" Value="Hand"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="Bd" Background="#161B22" CornerRadius="8" Padding="14,11" Margin="0,0,0,8"
                                                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                                                    <ContentPresenter/>
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#1C2128"/>
                                                    </Trigger>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="Bd" Property="Background" Value="#172A45"/>
                                                        <Setter TargetName="Bd" Property="BorderBrush" Value="#58A6FF"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <!-- Inner content (Background handled by ListBoxItem template) -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        
                                        <!-- Tier Badge -->
                                        <Border x:Name="tb" Grid.Column="0" CornerRadius="6" Padding="8,4" Margin="0,0,14,0"
                                                Width="40" Background="#2D333B" VerticalAlignment="Center">
                                            <TextBlock x:Name="tt" Text="{Binding Tier}" FontWeight="Black"
                                                       FontSize="14" Foreground="#FFD700" HorizontalAlignment="Center"/>
                                        </Border>

                                        <!-- Name & Role -->
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="#E6EDF3"/>
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <TextBlock Text="{Binding Role}" FontSize="12" Foreground="#8B949E" Margin="0,0,10,0"/>
                                                <TextBlock Text="{Binding Element}" FontSize="12" Foreground="#58A6FF"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Arrow Icon (Optional) -->
                                        <TextBlock Grid.Column="2" Text="›" FontSize="20" Foreground="#484F58"
                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    </Grid>

                                    <!-- Trigger for Tier Colors ONLY -->
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding Tier}" Value="T0">
                                            <Setter TargetName="tb" Property="Background" Value="#3D2E00"/>
                                            <Setter TargetName="tt" Property="Foreground" Value="#FFD700"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="SS">
                                            <Setter TargetName="tb" Property="Background" Value="#3D1518"/>
                                            <Setter TargetName="tt" Property="Foreground" Value="#FF6B6B"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="S">
                                            <Setter TargetName="tb" Property="Background" Value="#12284A"/>
                                            <Setter TargetName="tt" Property="Foreground" Value="#58A6FF"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Tier}" Value="A">
                                            <Setter TargetName="tb" Property="Background" Value="#1A3320"/>
                                            <Setter TargetName="tt" Property="Foreground" Value="#3FB950"/>
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>

                    <!-- ─── Right: Team Analysis Panel ─── -->
                    <Border Grid.Column="1" CornerRadius="12" Padding="20,18"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#161B22" Offset="0"/>
                                <GradientStop Color="#13171E" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>

                                <!-- Meta Score Card -->
                                <Border CornerRadius="10" Padding="20,16" Margin="0,0,0,18"
                                        BorderBrush="#3D2E00" BorderThickness="1">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                            <GradientStop Color="#1A1500" Offset="0"/>
                                            <GradientStop Color="#0D1117" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="META SCORE" FontSize="11" FontWeight="Bold"
                                                   Foreground="#8B949E" HorizontalAlignment="Center"
                                                   Margin="0,0,0,6"/>
                                        <TextBlock Text="{Binding MetaScoreText}" FontSize="32" FontWeight="Bold"
                                                   Foreground="#FFD700" HorizontalAlignment="Center"/>
                                        <TextBlock Text="{Binding MetaRating}" FontSize="14" FontWeight="SemiBold"
                                                   Foreground="#58A6FF" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                                    </StackPanel>
                                </Border>

                                <!-- Coverage Report -->
                                <TextBlock Text="COVERAGE REPORT" FontSize="11" FontWeight="Bold"
                                           Foreground="#484F58" Margin="0,0,0,8"/>
                                <Border Background="#0D1117" CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                                        BorderBrush="#21262D" BorderThickness="1">
                                    <ItemsControl ItemsSource="{Binding CoverageReport}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="13" Foreground="#C9D1D9"
                                                           Margin="0,3" LineHeight="18"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Warnings -->
                                <TextBlock Text="WARNINGS" FontSize="11" FontWeight="Bold"
                                           Foreground="#D29922" Margin="0,0,0,8"/>
                                <Border Background="#2A1A00" CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                                        BorderBrush="#3D2700" BorderThickness="1">
                                    <ItemsControl ItemsSource="{Binding Warnings}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#F0C674"
                                                           TextWrapping="Wrap" Margin="0,3" LineHeight="18"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                                <!-- Synergies -->
                                <TextBlock Text="TEAM SYNERGY" FontSize="11" FontWeight="Bold"
                                           Foreground="#8A2BE2" Margin="0,0,0,8"/>
                                <Border Background="#1A0B2E" CornerRadius="8" Padding="14,10" Margin="0,0,0,16"
                                        BorderBrush="#4B0082" BorderThickness="1">
                                    <ItemsControl ItemsSource="{Binding Synergies}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="12.5" Foreground="#DDA0DD"
                                                           TextWrapping="Wrap" Margin="0,3" LineHeight="18"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                        <ItemsControl.Style>
                                            <Style TargetType="ItemsControl">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Synergies.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </ItemsControl.Style>
                                    </ItemsControl>
                                </Border>

                                <!-- Team Analysis -->
                                <TextBlock Text="TEAM ANALYSIS" FontSize="11" FontWeight="Bold"
                                           Foreground="#484F58" Margin="0,0,0,8"/>
                                <Border Background="#0D1117" CornerRadius="8" Padding="14,10"
                                        BorderBrush="#21262D" BorderThickness="1">
                                    <ItemsControl ItemsSource="{Binding TeamAnalysis}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" FontSize="12" Foreground="#C9D1D9"
                                                           TextWrapping="Wrap" Margin="0,2" LineHeight="18"/>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>

                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- ═══════════════════════════════════════════════════ -->
        <!-- ═══ STATUS BAR ═══ -->
        <!-- ═══════════════════════════════════════════════════ -->
        <Border Grid.Row="2" Padding="20,10" BorderThickness="0,1,0,0"
                BorderBrush="{StaticResource BorderBrush}" Background="#13171E">
            <Grid>
                <TextBlock Text="{Binding StatusText}" FontSize="12"
                           Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center"/>
                <TextBlock HorizontalAlignment="Right" FontSize="11" VerticalAlignment="Center">
                    <Run Text="Star Savior Meta Tool  ·  " Foreground="#484F58"/>
                    <Run Text="Source-Verified Data Only" Foreground="#3FB950"/>
                </TextBlock>
            </Grid>
        </Border>
    </Grid>
</Window>
